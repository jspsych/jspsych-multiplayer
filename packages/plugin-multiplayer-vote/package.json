  "peerDependencies": {
    "jspsych": ">=8.0.0"
  },
  "devDependencies": {
    "jspsych": "^8.0.0",
    "@jspsych/config": "^3.2.2",
    "@jspsych/test-utils": "^1.0.0"
  }
